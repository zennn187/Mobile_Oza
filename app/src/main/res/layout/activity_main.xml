<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitleDatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Hitung Luas Persegi Panjang"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etPanjangDatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Panjang"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitleDatar" />

        <EditText
            android:id="@+id/etLebarDatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Lebar"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/etPanjangDatar" />

        <Button
            android:id="@+id/btnHitungDatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hitung Luas"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etLebarDatar" />

        <TextView
            android:id="@+id/tvHasilDatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hasil Luas: 0"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnHitungDatar"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#CCCCCC"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvHasilDatar" />

        <TextView
            android:id="@+id/tvTitleRuang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Hitung Volume Balok"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etPanjangRuang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Panjang"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitleRuang" />

        <EditText
            android:id="@+id/etLebarRuang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Lebar"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/etPanjangRuang" />

        <EditText
            android:id="@+id/etTinggiRuang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Masukkan Tinggi"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/etLebarRuang" />

        <Button
            android:id="@+id/btnHitungRuang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hitung Volume"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etTinggiRuang" />

        <TextView
            android:id="@+id/tvHasilRuang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hasil Volume: 0"
            android:textSize="16sp"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnHitungRuang"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>